#!/usr/bin/env bash
# Launcher — run from the SAGE-Viewer directory or add this directory to PATH.
# Explicitly adds user site-packages to PYTHONPATH so dependencies installed
# via 'pip install --user' (e.g. trame) are found by the system python3.
_USER_SITE="$(python3 -m site --user-site 2>/dev/null)"
PYTHONPATH="${_USER_SITE}${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m sage_viewer.cli "$@"
