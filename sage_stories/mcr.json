    {
      "id": "summary",
      "title": "Summary",
      "caption": "",
      "snap_num": "last",
      "camera": "box",
      "models": { "primary": "millennium", "adjacent": [] },
      "state": {
        "halos_visible": true,
        "galaxies_visible": true,
        "galaxy_color_mode": "structure"
