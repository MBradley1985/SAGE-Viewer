        {
          "kind": "text",
          "text": "14 Jul 2026   —   Mid-Candidature Review  ◀ today\n\nAug 2026   —   300 Collaboration Annual Meeting\n\nOct 2026   —   SAGE26 Papers I (model) & II (FFBs) submitted\n\nNov 2026   —   CDM ECR / Annual Workshop / Conference\n\nJan 2027   —   SAGE26 Paper III (ICS) submitted, or with Papers I & II\n\nFeb 2027   —   Paper IV — High-z MQGs  (Karl, Darren, Harry, Amrita & Jayde)\n\nMar 2027   —   Thesis writing\n\nMay / Jun 2027   —   Draft thesis review\n\nSep 2027   —   Thesis submission",
          "anchor": "top", "y": 28, "align": "center", "size": 1.1, "max_width": 78
        }
