{
  "schema_version": 1,
  "title": "Smoke Test (dev)",
  "author": "dev",
  "description": "Exercises the less-trodden Story Mode paths with NO hardcoded model names: structure color-mode + colormap changes, model switching with filters (primary 'other' = auto-pick another available model), and multi-box side-by-side evolution (adjacent 'auto'). Self-adapting to whatever output is connected. Not shipped.",
  "theme": "dos_blue",
  "requirements": {},
  "scenes": [
    {
      "id": "col-structure",
      "title": "Structure mode (baseline)",
      "caption": "Galaxies coloured by their internal structure composition.",
      "snap_num": "last",
      "camera": "box",
      "models": { "primary": "current" },
      "state": {
        "galaxies_visible": true, "halos_visible": true, "halo_opacity": 0.12,
        "galaxy_color_mode": "structure",
        "halo_color_mode": "mvir", "halo_colormap": "viridis"
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 3.0 },
      "dwell_secs": 4.0,
      "motion": { "kind": "still" }
    },
    {
      "id": "col-smass",
      "title": "Colour by stellar mass · plasma",
      "caption": "Switching the galaxy colour-by to stellar mass with the plasma colormap.",
      "snap_num": "last",
      "camera": "box",
      "state": {
        "galaxy_color_mode": "stellar_mass", "galaxy_colormap": "plasma",
        "halo_color_mode": "mvir", "halo_colormap": "viridis"
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 2.0 },
      "dwell_secs": 4.0,
      "motion": { "kind": "still" }
    },
    {
      "id": "col-ssfr",
      "title": "Colour by sSFR · turbo",
      "caption": "Specific star-formation rate with turbo; haloes by Rvir (inferno).",
      "snap_num": "last",
      "camera": "box",
      "state": {
        "galaxy_color_mode": "ssfr", "galaxy_colormap": "turbo",
        "halo_color_mode": "rvir", "halo_colormap": "inferno"
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 2.0 },
      "dwell_secs": 4.0,
      "motion": { "kind": "still" }
    },
    {
      "id": "model-current",
      "title": "Current model",
      "caption": "Structure colours on the launched model before switching.",
      "snap_num": "last",
      "camera": "box",
      "models": { "primary": "current" },
      "state": {
        "galaxy_color_mode": "structure",
        "galaxy_colormap": "plasma", "halo_color_mode": "mvir", "halo_colormap": "viridis"
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 2.0 },
      "dwell_secs": 4.0,
      "motion": { "kind": "still" }
    },
    {
      "id": "model-switch-filter",
      "title": "Switch to another model + filter massive",
      "caption": "Switching the active model to another available one and filtering to massive galaxies (log M* > 10.5) and clusters (log Mvir > 13).",
      "snap_num": "60%",
      "camera": "box",
      "models": { "primary": "other" },
      "state": {
        "galaxy_color_mode": "stellar_mass", "galaxy_colormap": "plasma",
        "filter_gal_smass": [10.5, 14.0],
        "filter_halo_mvir": [13.0, 15.0]
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 3.0 },
      "dwell_secs": 5.0,
      "motion": { "kind": "still" }
    },
    {
      "id": "model-back-reset",
      "title": "Back to current model + reset filters",
      "caption": "Switching back to the launched model and resetting the filters to their defaults.",
      "snap_num": "last",
      "camera": "box",
      "models": { "primary": "current" },
      "state": {
        "galaxy_color_mode": "structure",
        "filter_gal_smass": [0.0, 14.0],
        "filter_halo_mvir": [10.0, 15.0]
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 3.0 },
      "dwell_secs": 4.0,
      "motion": { "kind": "still" }
    },
    {
      "id": "multibox-evolve",
      "title": "Two boxes, side-by-side, evolving",
      "caption": "Loading a second model side-by-side and evolving both from high-z to low-z.",
      "snap_num": "40%",
      "camera": "box",
      "models": { "primary": "current", "adjacent": ["auto"] },
      "state": {
        "galaxies_visible": true, "halos_visible": true, "halo_opacity": 0.12,
        "galaxy_color_mode": "structure"
      },
      "chrome": { "hide_panel": true },
      "transition": { "duration_secs": 3.0 },
      "dwell_secs": 1.0,
      "motion": { "kind": "snapshot_sweep", "from": "40%", "to": "last", "fps": 4.0 }
    }
  ]
}
